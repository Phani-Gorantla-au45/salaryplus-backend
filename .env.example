# ============================================================
# SalaryPlus Backend — Environment Variables
# Copy this file to .env and fill in actual values
# NEVER commit .env to version control
# ============================================================

# Server
PORT=3000

# Database
MONGO_URI=mongodb+srv://your_connection_string_here

# JWT
JWT_SECRET=your_jwt_secret_here

# Admin
ADMIN_PHONE=your_admin_phone_here

# ---- Gold (Augmont) ----
AUG_URL=https://...
AUGMONT_TOKEN=Bearer_...

# ---- Gold KYC (Cashfree) ----
CASHFREE_URL=https://...
CASHFREE_PAN_CLIENT_ID=your_cashfree_client_id
CASHFREE_PAN_CLIENT_SECRET=your_cashfree_client_secret

# ---- Payment (Juspay) ----
JUSPAY_HOST=https://...
JUSPAY_MERCHANTID=your_juspay_merchant_id
JUSPAY_CHANNELID=your_juspay_channel_id
JUSPAY_KID=your_juspay_kid

# ============================================================
# Mutual Funds — Cybrilla / FintechPrimitives
# Sandbox credentials — replace with production for live
# ============================================================
CYBRILLA_AUTH_URL=https://s.finprim.com
CYBRILLA_API_URL=https://api.sandbox.cybrilla.com
CYBRILLA_CLIENT_ID=your_cybrilla_client_id
CYBRILLA_CLIENT_SECRET=your_cybrilla_client_secret

# ---- Mutual Funds — FintechPrimitives KYC Request API ----
FP_API_URL=https://s.finprim.com
FP_TENANT_ID=sipway
FP_CLIENT_ID=your_fp_client_id
FP_CLIENT_SECRET=your_fp_client_secret
